# .gitignore base para Go y Flutter

# Mac/OSX
.DS_Store

# Go
/bin/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
vendor/

# Environment Variables
.env
.env.*.local
*.secret

# Local Storage (development only)
storage/

# Docker PostgreSQL Data (development only)
postgres_data/

# Google Cloud Service Account credentials — NEVER commit these!
# These files contain private keys. Treat them like passwords.
*.json
!package.json
!package-lock.json

# Flutter / Dart
build/
.dart_tool/
.packages
.pub-cache/
.pub/
/android/app/src/profile/
/android/app/src/release/
/ios/Flutter/App.framework
/ios/Flutter/Flutter.framework
/ios/Flutter/Flutter.podspec
/ios/Flutter/Generated.xcconfig
/ios/Flutter/app.flx
/ios/Flutter/app.zip
/ios/Flutter/flutter_assets/
/ios/Flutter/flutter_export_environment.sh
/ios/Pods/
/ios/.symlinks/

# IDE / Editor
.idea/
.vscode/
*.iml
*.swp

# TestSprite (generated artifacts)
testsprite_tests/tmp/
testsprite_tests/*.py
testsprite_tests/*.html
!testsprite_tests/testsprite-mcp-test-report.md

# OpenSpec (should be tracked)
