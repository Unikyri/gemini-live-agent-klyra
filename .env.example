# Google Cloud / Vertex AI / Gemini
GCP_PROJECT_ID=klyra-dev-1234
GCP_REGION=us-central1
GEMINI_API_KEY=your_gemini_api_key_here

# Google Cloud Service Account (development only — NEVER commit the actual JSON file!)
# Point this to the SERVICE ACCOUNT JSON file downloaded from GCP Console.
# In production (Cloud Run), remove this variable — authentication is handled automatically.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account.json

# Vertex AI Imagen
IMAGEN_MODEL_ID=imagen-3.0-generate-001

# Google Cloud Storage
# Leave empty to auto-generate: <GCP_PROJECT_ID>-klyra-assets
GCS_BUCKET_NAME=

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=klyra_dev
DB_SSL_MODE=disable

# API / Backend Server
PORT=8080
ENV=development

# JWT & Security
JWT_SECRET=your_super_secret_jwt_key
REFRESH_TOKEN_SECRET=your_super_secret_refresh_key

# CORS — set this to the origin (scheme+host+port) that is allowed to call the API.
# In development: http://localhost:3000  |  In production: your actual frontend/admin origin.
# Flutter mobile apps do not use CORS (native HTTP clients), but the admin or web client might.
ALLOWED_ORIGIN=http://localhost:3000
